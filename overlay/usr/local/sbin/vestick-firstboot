#!/bin/bash
# VEstick first-boot setup wizard. Single console-interactive script that
# runs once, gated by /var/lib/vestick/.firstboot-done. Prompts the
# operator for hostname + root password, then NIC + static IP/CIDR +
# gateway + DNS — same shape as the stock Proxmox installer's network
# step. Writes /etc/hostname, /etc/shadow, /etc/network/interfaces and
# /etc/hosts together. /etc and /var/lib are on the persistent f2fs
# overlay, so writes are normal in-place edits.
#
# SSH host keys are generated separately by vestick-sshkeys.service at
# sysinit, before this wizard runs.

set -euo pipefail

MARKER=/var/lib/vestick/.firstboot-done
INTERFACES=/etc/network/interfaces
HOSTS=/etc/hosts
mkdir -p "$(dirname "$MARKER")"

[[ -e "$MARKER" ]] && exit 0

# Physical interfaces only: must have a /sys/.../device link (rules out lo,
# dummy, vlans), must not be a bridge. Virtio NICs in QEMU pass this filter.
mapfile -t ifaces < <(
    for d in /sys/class/net/*; do
        n=$(basename "$d")
        [[ "$n" == "lo" ]] && continue
        [[ -e "$d/device" ]] || continue
        [[ -e "$d/bridge" ]] && continue
        echo "$n"
    done | sort
)

if [[ ${#ifaces[@]} -eq 0 ]]; then
    echo "vestick-firstboot: no physical interfaces found" >&2
    exit 1
fi

clear || true
cat <<'BANNER'
╔══════════════════════════════════════════════════════╗
║                 VEstick first-boot setup             ║
║   identity (hostname + root password) and network    ║
╚══════════════════════════════════════════════════════╝

BANNER

# --- identity ----------------------------------------------------------------

current=$(cat /etc/hostname 2>/dev/null || echo "vestick")
read -rp "System hostname [$current]: " hostname
hostname="${hostname:-$current}"
echo "$hostname" > /etc/hostname
hostname "$hostname"

while :; do
    read -rsp "Root password: " pw1; echo
    read -rsp "Confirm root password: " pw2; echo
    [[ -n "$pw1" && "$pw1" == "$pw2" ]] && break
    echo "Passwords don't match (or empty), try again." >&2
done
echo "root:$pw1" | chpasswd
unset pw1 pw2

# --- network -----------------------------------------------------------------

echo
echo "Available interfaces:"
default=""
for n in "${ifaces[@]}"; do
    mac=$(cat "/sys/class/net/$n/address" 2>/dev/null || echo "?")
    state=$(cat "/sys/class/net/$n/operstate" 2>/dev/null || echo "?")
    printf '  %-12s  mac=%s  link=%s\n' "$n" "$mac" "$state"
    [[ -z "$default" && "$state" == "up" ]] && default="$n"
done
default="${default:-${ifaces[0]}}"

read -rp "Interface to bridge into vmbr0 [$default]: " choice
choice="${choice:-$default}"

valid=0
for n in "${ifaces[@]}"; do
    [[ "$choice" == "$n" ]] && valid=1
done
if [[ "$valid" -ne 1 ]]; then
    echo "vestick-firstboot: '$choice' not in interface list, aborting" >&2
    exit 1
fi

# Static IP/CIDR. Validate basic shape; ifupdown will catch the rest.
while :; do
    read -rp "Static IP/CIDR (e.g. 192.0.2.10/24): " ipcidr
    if [[ "$ipcidr" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]]; then
        break
    fi
    echo "Format must be A.B.C.D/N." >&2
done
ip="${ipcidr%/*}"

read -rp "Default gateway [$(echo "$ip" | awk -F. '{print $1"."$2"."$3".1"}')]: " gw
gw="${gw:-$(echo "$ip" | awk -F. '{print $1"."$2"."$3".1"}')}"

read -rp "DNS nameserver [$gw]: " dns
dns="${dns:-$gw}"

cat > "$INTERFACES" <<EOF
# Generated by vestick-firstboot on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# The Proxmox web UI replaces this with a libpve-common-perl-formatted
# version (with the canonical "do NOT modify" header) on the first edit.
auto lo
iface lo inet loopback

iface $choice inet manual

auto vmbr0
iface vmbr0 inet static
    address $ipcidr
    gateway $gw
    bridge-ports $choice
    bridge-stp off
    bridge-fd 0
    dns-nameservers $dns
EOF

cat > "$HOSTS" <<EOF
127.0.0.1 localhost
$ip $hostname

::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOF

touch "$MARKER"
echo
echo "vestick-firstboot: hostname=$hostname, vmbr0 over $choice, $ipcidr gw $gw dns $dns"
