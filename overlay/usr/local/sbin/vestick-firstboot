#!/bin/bash
# VEstick first-boot identity setup. Runs once on the console to prompt
# for hostname and root password. /etc and /var/lib are on the persistent
# f2fs overlay, so writes are normal in-place edits.
#
# SSH host keys are NOT regenerated here — that's handled by the
# ssh.service ExecStartPre drop-in (overlay/etc/systemd/system/ssh.service.d/
# vestick-keygen.conf), which runs `ssh-keygen -A` idempotently before
# every sshd start. With /etc/ssh on the persistent overlay, keys are
# created on first boot and persist after.

set -euo pipefail

MARKER=/var/lib/vestick/.firstboot-done
mkdir -p "$(dirname "$MARKER")"

[[ -e "$MARKER" ]] && exit 0

echo
echo "=== VEstick first-boot setup ==="

current=$(cat /etc/hostname 2>/dev/null || echo "vestick")
read -rp "System hostname [$current]: " hostname
hostname="${hostname:-$current}"
echo "$hostname" > /etc/hostname
hostname "$hostname"

while :; do
    read -rsp "Root password: " pw1; echo
    read -rsp "Confirm root password: " pw2; echo
    [[ -n "$pw1" && "$pw1" == "$pw2" ]] && break
    echo "Passwords don't match (or empty), try again." >&2
done

echo "root:$pw1" | chpasswd
unset pw1 pw2

touch "$MARKER"
echo "vestick-firstboot: hostname=$hostname, root password set"
