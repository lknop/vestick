#!/bin/bash
# Write a tmpfs-backed /etc/hosts that maps the local hostname to the
# current primary IP. pmxcfs (and most cluster software) refuse to start
# without a non-loopback hostname mapping, but on a ro root we can't
# persist /etc/hosts edits across DHCP IP changes — so we generate at
# boot time into /run/hosts and bind-mount it over /etc/hosts.
#
# To update mid-boot (e.g. after DHCP renewal): just rewrite /run/hosts.
# Bind mount means the change is visible at /etc/hosts immediately.

set -euo pipefail

TMPHOSTS=/run/hosts
HOSTNAME=$(tr -d '[:space:]' < /etc/hostname 2>/dev/null || hostname)

# Primary IPv4: prefer the source address that would be used to reach an
# arbitrary off-box destination (this is the IP cluster peers see). Fall
# back to the first global-scope address on any interface. Both `ip`
# invocations may legitimately return non-zero (no default route, no
# global-scope address) — guard with || : so set -e+pipefail tolerates that.
ip=$( { ip -4 -o route get 1.1.1.1 2>/dev/null || :; } \
        | sed -n 's/.* src \([0-9.]*\).*/\1/p' | head -1 )
if [[ -z "${ip:-}" ]]; then
    ip=$( { ip -4 -o addr show scope global 2>/dev/null || :; } \
            | awk '{print $4}' | cut -d/ -f1 | head -1 )
fi
# Last-resort fallback. pmxcfs treats 127.0.1.1 as loopback and still
# refuses, but at least the box boots far enough for the operator to
# log in and fix networking.
[[ -n "${ip:-}" ]] || ip=127.0.1.1

cat > "$TMPHOSTS" <<EOF
# Generated by veyage-hosts-init at $(date -u +%Y-%m-%dT%H:%M:%SZ).
# /etc/hosts is bind-mounted from /run/hosts on this box — edits here
# survive only until the next boot. To make a change persist, edit
# /etc/hosts under a remountrw window and remove this bind mount, OR
# extend veyage-hosts-init to honour an /etc/hosts.local file.
127.0.0.1 localhost
$ip $HOSTNAME

::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOF

# Bind-mount idempotently. findmnt --target prints non-empty when mounted.
if [[ -z "$(findmnt -n --target /etc/hosts --source "$TMPHOSTS" 2>/dev/null)" ]]; then
    mount --bind "$TMPHOSTS" /etc/hosts
fi

echo "veyage-hosts-init: $HOSTNAME -> $ip"
