#!/bin/bash
# VEyage first-boot interactive network setup. Prompts for the management
# NIC, static IP/CIDR, gateway, and DNS — same shape as the stock Proxmox
# installer. Writes /etc/network/interfaces (vmbr0 bridged onto the NIC)
# and /etc/hosts (hostname → static IP) together. Idempotent: subsequent
# boots see vmbr0 already declared and exit immediately.
#
# Both files sit on the persistent f2fs overlay; the operator can edit
# them later via the Proxmox web UI or by hand.

set -euo pipefail

INTERFACES=/etc/network/interfaces
HOSTS=/etc/hosts

if [[ -f "$INTERFACES" ]] && grep -q '^auto vmbr0' "$INTERFACES"; then
    exit 0
fi

# Physical interfaces only: must have a /sys/.../device link (rules out lo,
# dummy, vlans), must not be a bridge. Virtio NICs in QEMU pass this filter.
mapfile -t ifaces < <(
    for d in /sys/class/net/*; do
        n=$(basename "$d")
        [[ "$n" == "lo" ]] && continue
        [[ -e "$d/device" ]] || continue
        [[ -e "$d/bridge" ]] && continue
        echo "$n"
    done | sort
)

if [[ ${#ifaces[@]} -eq 0 ]]; then
    echo "veyage-network-init: no physical interfaces found" >&2
    exit 1
fi

echo
echo "=== VEyage first-boot network setup ==="
echo "Available interfaces:"
default=""
for n in "${ifaces[@]}"; do
    mac=$(cat "/sys/class/net/$n/address" 2>/dev/null || echo "?")
    state=$(cat "/sys/class/net/$n/operstate" 2>/dev/null || echo "?")
    printf '  %-12s  mac=%s  link=%s\n' "$n" "$mac" "$state"
    [[ -z "$default" && "$state" == "up" ]] && default="$n"
done
default="${default:-${ifaces[0]}}"

read -rp "Interface to bridge into vmbr0 [$default]: " choice
choice="${choice:-$default}"

valid=0
for n in "${ifaces[@]}"; do
    [[ "$choice" == "$n" ]] && valid=1
done
if [[ "$valid" -ne 1 ]]; then
    echo "veyage-network-init: '$choice' not in interface list, aborting" >&2
    exit 1
fi

# Static IP/CIDR. Validate basic shape; ifupdown will catch the rest.
while :; do
    read -rp "Static IP/CIDR (e.g. 192.0.2.10/24): " ipcidr
    if [[ "$ipcidr" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]]; then
        break
    fi
    echo "Format must be A.B.C.D/N." >&2
done
ip="${ipcidr%/*}"

read -rp "Default gateway [$(echo "$ip" | awk -F. '{print $1"."$2"."$3".1"}')]: " gw
gw="${gw:-$(echo "$ip" | awk -F. '{print $1"."$2"."$3".1"}')}"

read -rp "DNS nameserver [$gw]: " dns
dns="${dns:-$gw}"

hostname=$(tr -d '[:space:]' < /etc/hostname 2>/dev/null || echo veyage)

cat > "$INTERFACES" <<EOF
# Generated by veyage-network-init on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# The Proxmox web UI replaces this with a libpve-common-perl-formatted
# version (with the canonical "do NOT modify" header) on the first edit.
auto lo
iface lo inet loopback

iface $choice inet manual

auto vmbr0
iface vmbr0 inet static
    address $ipcidr
    gateway $gw
    bridge-ports $choice
    bridge-stp off
    bridge-fd 0
    dns-nameservers $dns
EOF

cat > "$HOSTS" <<EOF
127.0.0.1 localhost
$ip $hostname

::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOF

echo "veyage-network-init: vmbr0 over $choice, $ipcidr gw $gw dns $dns"
echo "veyage-network-init: $hostname -> $ip in $HOSTS"
