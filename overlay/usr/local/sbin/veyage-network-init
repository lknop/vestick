#!/bin/bash
# VEyage first-boot interactive vmbr0 setup. Lists physical interfaces at
# the console, prompts for one to bridge into vmbr0, writes the stanza
# into /etc/network/interfaces. Idempotent: subsequent runs see vmbr0
# already declared and exit cleanly.
#
# Runs from veyage-network-init.service which wraps this in a remount-rw /
# remount-ro window (the rootfs is ro by default).

set -euo pipefail

INTERFACES=/etc/network/interfaces

if [[ -f "$INTERFACES" ]] && grep -q '^auto vmbr0' "$INTERFACES"; then
    exit 0
fi

# Physical interfaces only: must have /sys/.../device (rules out lo,
# dummy, vlans), must not be a bridge. Virtio NICs in QEMU pass.
mapfile -t ifaces < <(
    for d in /sys/class/net/*; do
        n=$(basename "$d")
        [[ "$n" == "lo" ]] && continue
        [[ -e "$d/device" ]] || continue
        [[ -e "$d/bridge" ]] && continue
        echo "$n"
    done | sort
)

if [[ ${#ifaces[@]} -eq 0 ]]; then
    echo "veyage-network-init: no physical interfaces found" >&2
    exit 1
fi

echo
echo "=== VEyage first-boot network setup ==="
echo "Available interfaces:"
default=""
for n in "${ifaces[@]}"; do
    mac=$(cat "/sys/class/net/$n/address" 2>/dev/null || echo "?")
    state=$(cat "/sys/class/net/$n/operstate" 2>/dev/null || echo "?")
    printf '  %-12s  mac=%s  link=%s\n' "$n" "$mac" "$state"
    [[ -z "$default" && "$state" == "up" ]] && default="$n"
done
default="${default:-${ifaces[0]}}"

read -rp "Interface to bridge into vmbr0 [$default]: " choice
choice="${choice:-$default}"

valid=0
for n in "${ifaces[@]}"; do
    [[ "$choice" == "$n" ]] && valid=1
done
if [[ "$valid" -ne 1 ]]; then
    echo "veyage-network-init: '$choice' not in interface list, aborting" >&2
    exit 1
fi

cat > "$INTERFACES" <<EOF
# Generated by veyage-network-init on $(date -u +%Y-%m-%dT%H:%M:%SZ).
# Proxmox's web UI replaces this with a libpve-common-perl-formatted version
# (with the canonical "do NOT modify" header) on the first edit.
auto lo
iface lo inet loopback

iface $choice inet manual

auto vmbr0
iface vmbr0 inet dhcp
    bridge-ports $choice
    bridge-stp off
    bridge-fd 0
EOF
echo "veyage-network-init: wrote $INTERFACES with vmbr0 over $choice"
