#!/bin/bash
# VEyage state partition setup. Runs as a systemd oneshot after
# mnt-state.mount and before basic.target.
#
# First boot (state partition is empty):
#   - copy current squashfs contents of each persisted path into /mnt/state
#   - regenerate fresh per-host SSH keys (replacing the build-time keys)
#   - touch a marker so we don't re-init on next boot
#
# Every boot:
#   - bind-mount each populated path from /mnt/state over the running rootfs
#
# If a target doesn't exist in the running system (e.g. /var/lib/pve-cluster
# before the Proxmox layer is installed), the bind is skipped — adding new
# packages later just starts using state automatically without needing to
# re-image.

set -euo pipefail

STATE=/mnt/state
MARKER="$STATE/.veyage-initialized"

mountpoint -q "$STATE" || { echo "veyage-state: $STATE not mounted, aborting" >&2; exit 1; }

# First-boot resize: grow the state partition to fill the actual device, then
# online-grow the ext4 to match. Idempotent — growpart returns non-zero when
# nothing to grow, resize2fs on an already-full FS is a no-op.
state_dev=$(findmnt -nro SOURCE "$STATE")
parent_disk=$(lsblk -nro PKNAME "$state_dev" 2>/dev/null | head -1)
part_num=$(echo "$state_dev" | grep -oE '[0-9]+$')
if [[ -n "$parent_disk" && -n "$part_num" ]]; then
    # Fix up GPT to use full disk size if image was dd'd to a larger device.
    sgdisk -e "/dev/$parent_disk" >/dev/null 2>&1 || true
    if growpart "/dev/$parent_disk" "$part_num" >/dev/null 2>&1; then
        echo "veyage-state: grew /dev/$parent_disk partition $part_num"
        resize2fs "$state_dev" >/dev/null 2>&1 && \
            echo "veyage-state: resized $state_dev"
    fi
fi

# Paths to persist. Each entry is a path relative to /. New paths can be
# added here later without breaking existing state partitions.
PERSIST_PATHS=(
    etc/network
    etc/ssh
    etc/hostname
    etc/shadow
    var/lib/pve-cluster
    var/lib/rrdcached
)

# Seed any missing path on /mnt/state from the running squashfs. Per-path
# idempotent (skips entries that already exist on /mnt/state), so adding
# new entries to PERSIST_PATHS in a later build picks them up automatically
# on the next boot — without re-bootstrapping the whole state partition.
for p in "${PERSIST_PATHS[@]}"; do
    src="/$p"
    dest="$STATE/$p"
    if [[ -e "$src" && ! -e "$dest" ]]; then
        mkdir -p "$(dirname "$dest")"
        cp -a "$src" "$dest"
    fi
done

if [[ ! -e "$MARKER" ]]; then
    echo "veyage-state: first boot, regenerating per-host SSH keys"
    # Replace build-time SSH host keys with fresh per-host keys. Without this,
    # every image built from the same source would have identical keys. Gated
    # on the marker so the keys are only regenerated once per state partition.
    if [[ -d "$STATE/etc/ssh" ]]; then
        rm -f "$STATE/etc/ssh/"ssh_host_*_key "$STATE/etc/ssh/"ssh_host_*_key.pub
        for kt in rsa ecdsa ed25519; do
            ssh-keygen -t "$kt" -f "$STATE/etc/ssh/ssh_host_${kt}_key" -N '' -q
        done
        chmod 600 "$STATE/etc/ssh/"ssh_host_*_key
        chmod 644 "$STATE/etc/ssh/"ssh_host_*_key.pub
    fi

    touch "$MARKER"
fi

# Bind-mount persisted paths over the running rootfs. Idempotent — if a path
# is already a mountpoint we leave it alone.
for p in "${PERSIST_PATHS[@]}"; do
    src="$STATE/$p"
    dest="/$p"
    [[ -e "$src" ]] || continue
    [[ -e "$dest" ]] || continue
    if mountpoint -q "$dest"; then
        continue
    fi
    mount --bind "$src" "$dest"
    echo "veyage-state: bound $src → $dest"
done

# systemd reads /etc/hostname at PID 1 init — before this service runs —
# and sets the kernel hostname from the squashfs's value (the build-time
# default). After our bind, /etc/hostname reflects what veyage-firstboot
# wrote, but the kernel hostname is stale. Re-apply it from the now-bound
# file so getty banners and `hostname` command see the persisted value.
if [[ -f /etc/hostname ]]; then
    hn=$(cat /etc/hostname)
    [[ -n "$hn" ]] && hostname "$hn"
fi
