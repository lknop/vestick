[Unit]
Description=VEyage first-boot identity setup (systemd-firstboot in an rw window)
ConditionPathExists=!/var/lib/veyage/firstboot-done
After=local-fs.target
Before=veyage-network-init.service networking.service getty.target

[Service]
Type=oneshot
RemainAfterExit=yes
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/console
TTYReset=yes
TTYVHangup=yes
TimeoutStartSec=infinity
ExecStart=/usr/local/sbin/veyage-firstboot

[Install]
WantedBy=multi-user.target
