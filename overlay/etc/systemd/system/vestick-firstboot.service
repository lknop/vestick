[Unit]
Description=VEstick first-boot setup wizard (hostname, root password, network)
Before=networking.service getty.target
ConditionPathExists=!/var/lib/vestick/.firstboot-done

[Service]
Type=oneshot
RemainAfterExit=yes
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/console
TTYReset=yes
TTYVHangup=yes
TimeoutStartSec=infinity
ExecStart=/usr/local/sbin/vestick-firstboot

[Install]
WantedBy=networking.service
