# VEyage fstab. Root is mounted by initramfs via overlayroot (squashfs lower
# + f2fs upper); the ESP is mounted on demand by update-grub. The entries
# below route paths whose contents are continuously written and regenerable
# (logs, caches, perf RRDs) to RAM, so the f2fs overlay sees only writes
# that actually need to persist.
#
# Paths NOT listed here ride the persistent f2fs overlay by default —
# including /var/lib/systemd, /var/lib/postfix, /var/spool/postfix, and
# /var/lib/pve-manager (their writes are low-rate, and persistence is
# either useful — mail queue, timer stamps — or harmless).

tmpfs            /tmp                 tmpfs nodev,nosuid,size=512M           0  0
tmpfs            /var/tmp             tmpfs nodev,nosuid,size=128M           0  0
tmpfs            /var/log             tmpfs nodev,nosuid,size=128M           0  0

# /var/cache: apparmor recompiles its policy cache (~seconds), apt cache is
# regenerated by `apt update`. Treat as fully regenerable per FHS.
tmpfs            /var/cache           tmpfs nodev,nosuid,size=128M,mode=755  0  0

# rrdcached: PVE perf graphs reset on reboot. Continuous ~MB/hour write rate
# is the dominant flash writer on an idle PVE node — tmpfs trades graph
# history for sharply lower flash wear.
tmpfs            /var/lib/rrdcached   tmpfs nodev,nosuid,size=128M,mode=755  0  0

# Default Proxmox 'local' storage path. Empty placeholder dirs — operators
# who actually use local storage are expected to mount real storage here
# (or reconfigure /etc/pve/storage.cfg). Keeping on tmpfs guards against
# the accidental "I put my VM on the boot media" misuse case.
tmpfs            /var/lib/vz          tmpfs nodev,nosuid,size=32M,mode=755   0  0
