# Minimal additions on top of `debootstrap --variant=minbase trixie`.
# Keep this list tight — every entry needs justification.

# Init system. minbase doesn't ship one — without this, kernel boot drops
# to the initramfs recovery shell on `/sbin/init` not found. systemd-sysv
# pulls systemd as a hard dep and provides /sbin/init.
systemd-sysv
dbus

# Read-only root: overlayroot adds initramfs hooks that mount a persistent
# f2fs upper layer over the squashfs root, so PID 1 sees a fully writable /.
# Configured via overlay/etc/overlayroot.conf. e2fsprogs is needed because
# overlayroot's initramfs hook unconditionally bundles mke2fs (it's a
# Recommends, not a Depends, so --no-install-recommends would otherwise skip
# it). f2fs-tools provides mkfs.f2fs/fsck.f2fs/resize.f2fs — initramfs hook
# (overlay/etc/initramfs-tools/hooks/vestick-f2fs) copies them into initramfs
# for the first-boot mkfs; resize.f2fs runs at runtime via vestick-overlay-resize.
# busybox gives the initramfs a real `grep` (and friends) — without it,
# mkinitramfs falls back to klibc-utils, and overlayroot's init-bottom
# script silently fails its overlay-availability check.
overlayroot
e2fsprogs
f2fs-tools
busybox

# growpart for first-boot resize of the overlay partition. Lets us ship a
# small image and have it expand to fill the real device on first boot.
# gdisk provides sgdisk, which growpart calls for GPT disks (it's a
# Recommends of cloud-guest-utils so --no-install-recommends drops it).
cloud-guest-utils
gdisk

# Trust roots and apt prerequisites
ca-certificates
gnupg

# Locales (en_US.UTF-8 only, configured in overlay/)
locales

# Time sync — corosync is sensitive to clock skew
chrony

# Networking — Proxmox prefers ifupdown2 for bridges and VLANs
ifupdown2
bridge-utils
ethtool
iproute2
iputils-ping

# Remote access
openssh-server

# Minimal pager and editors (no full vim, no man-db). nano alongside
# vim-tiny because operators on Proxmox systems commonly default to it.
less
vim-tiny
nano
