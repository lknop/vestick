# Minimal additions on top of `debootstrap --variant=minbase trixie`.
# Keep this list tight — every entry needs justification.

# Init system. minbase doesn't ship one — without this, kernel boot drops
# to the initramfs recovery shell on `/sbin/init` not found. systemd-sysv
# pulls systemd as a hard dep and provides /sbin/init. libpam-systemd +
# libnss-systemd are Recommends of systemd-sysv, dropped by
# --no-install-recommends — without them systemd-logind crashloops on
# boot ("Failed to start systemd-logind.service") and login sessions
# don't get systemd scopes.
systemd-sysv
libpam-systemd
libnss-systemd
dbus

# Filesystem + boot-time resize tooling. e2fsprogs gives us mkfs.ext4,
# fsck, and resize2fs (the latter for first-boot growpart of the rootfs).
# growpart from cloud-guest-utils + sgdisk from gdisk handle GPT growth.
e2fsprogs
cloud-guest-utils
gdisk

# Bootloader. Standard Debian-managed grub-efi so apt can update it during
# a remountrw window. --removable plant happens at build time via
# build.sh::install_grub.
grub-efi-amd64

# Trust roots and apt prerequisites
ca-certificates
gnupg

# Locales (en_US.UTF-8 only, configured in overlay/)
locales

# Time sync — corosync is sensitive to clock skew
chrony

# Networking — Proxmox prefers ifupdown2 for bridges and VLANs
ifupdown2
bridge-utils
ethtool
iproute2
iputils-ping

# Remote access
openssh-server

# Minimal pager and editors (no full vim, no man-db). nano alongside
# vim-tiny because operators on Proxmox systems commonly default to it.
less
vim-tiny
nano
