# Minimal additions on top of `debootstrap --variant=minbase trixie`.
# Keep this list tight — every entry needs justification.

# Init system. minbase doesn't ship one — without this, kernel boot drops
# to the initramfs recovery shell on `/sbin/init` not found. systemd-sysv
# pulls systemd as a hard dep and provides /sbin/init.
systemd-sysv
dbus

# Read-only root: overlayroot adds initramfs hooks that mount a tmpfs upper
# layer over the (RO) root, so PID 1 sees a fully writable /. Configured via
# overlay/etc/overlayroot.conf. e2fsprogs is needed because overlayroot's
# initramfs hook unconditionally bundles mke2fs (it's a Recommends, not a
# Depends, so --no-install-recommends would otherwise skip it). busybox gives
# the initramfs a real `grep` (and friends) — without it, mkinitramfs falls
# back to klibc-utils, and overlayroot's init-bottom script silently fails
# its overlay-availability check.
overlayroot
e2fsprogs
busybox

# Trust roots and apt prerequisites
ca-certificates
gnupg

# Locales (en_US.UTF-8 only, configured in overlay/)
locales

# Time sync — corosync is sensitive to clock skew
chrony

# Networking — Proxmox prefers ifupdown2 for bridges and VLANs
ifupdown2
bridge-utils
ethtool
iproute2
iputils-ping

# Remote access
openssh-server

# Minimal pager and editor (no full vim, no man-db)
less
vim-tiny
